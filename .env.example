# KEON Control API Configuration

# API Base URL (backend)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/control

# API Request Timeout (milliseconds)
NEXT_PUBLIC_API_TIMEOUT=10000

# Use mock data fallback when API is unavailable
NEXT_PUBLIC_API_USE_MOCK_FALLBACK=true

# App origin for local billing redirects
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000

# Azure PostgreSQL Flexible Server connection string
DATABASE_URL=
DATABASE_POOL_MAX=5

# Live Mode - set to true to use real API, false to use mock data
NEXT_PUBLIC_API_LIVE_MODE=false

# Stripe billing integration
# Leave unset to use the local mock checkout + portal shim.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTUP=
STRIPE_PRICE_GROWTH=

# Live Collective host seam (server-side only)
# Required for /api/collective/live-runs and /collective/submit.
KEON_COLLECTIVE_HOST_BASE_URL=http://localhost:5122
KEON_COLLECTIVE_HOST_TIMEOUT_MS=15000

# Internal test activation
# Only honored outside production unless ALLOW_TEST_ACTIVATION=true.
KEON_TEST_ACTIVATION_TOKEN=
ALLOW_TEST_ACTIVATION=false

# Approved workspace setup magic links
# Public request submission does not generate these. Send after review/provisioning.
KEON_INVITE_ACTIVATION_TOKEN=
KEON_INVITE_ACTIVATION_TOKENS=
KEON_INVITE_TENANT_ID=
KEON_INVITE_TENANT_NAME=
KEON_INVITE_WORKSPACE_ID=
KEON_INVITE_WORKSPACE_NAME=
KEON_INVITE_ENVIRONMENT=sandbox
KEON_INVITE_UI_LABEL=Approved workspace setup

# Local dev onboarding bypass
# Set to true to skip tenant provisioning in Step 2 — injects the internal test workspace automatically.
# Never set this in production or staging.
NEXT_PUBLIC_ONBOARDING_LOCAL_MODE=false
