# Local Development Configuration
# Copy this file to .env.local and adjust as needed

NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/control
NEXT_PUBLIC_API_TIMEOUT=10000
NEXT_PUBLIC_API_USE_MOCK_FALLBACK=true
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
DATABASE_URL=
DATABASE_POOL_MAX=5

# Set to true when backend is running
NEXT_PUBLIC_API_LIVE_MODE=false

# Local website governance API facade (server-side)
# mock = always use local mock provider (clearly labeled MOCK in UI)
# live = proxy to KEON_CONTROL_GOVERNANCE_BASE_URL and fail closed on upstream errors
KEON_CONTROL_GOVERNANCE_MODE=mock
KEON_CONTROL_GOVERNANCE_BASE_URL=http://localhost:5000
KEON_CONTROL_GOVERNANCE_TIMEOUT_MS=5000

# Stripe billing integration
# Leave unset to use the local mock checkout + portal shim.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTUP=
STRIPE_PRICE_GROWTH=

# Real Collective host seam (server-side only)
# Used by the live submit workflow. No mock fallback is applied.
KEON_COLLECTIVE_HOST_BASE_URL=http://localhost:5122
KEON_COLLECTIVE_HOST_TIMEOUT_MS=15000
